<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>USA Streetlifting – Judge Certification</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <!-- ============ TOAST CONTAINER ============ -->
  <div id="toast-container"></div>

  <!-- ============ NAV ============ -->
  <nav id="navbar">
    <div class="nav-inner">
      <a class="logo" data-nav="home">
        <span class="logo-usa">USA</span> <span class="logo-sl">STREETLIFTING</span>
      </a>

      <!-- Hamburger for mobile -->
      <button id="hamburger" class="hamburger" data-action="toggle-menu" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>

      <div class="nav-links" id="nav-links">
        <a data-nav="home">Home</a>
        <a data-nav="about">About</a>
        <a data-nav="rules">Rules</a>
        <a id="nav-login" data-nav="login">Login</a>
        <a id="nav-register" data-nav="register">Register</a>
        <a id="nav-dashboard" data-nav="dashboard" class="hidden">Dashboard</a>
        <a id="nav-profile" data-nav="profile" class="hidden">Profile</a>
        <a id="nav-payment" data-nav="payment" class="hidden">Pay</a>
        <a id="nav-logout" data-action="logout" class="hidden btn-nav">Logout</a>
      </div>
    </div>
  </nav>

  <!-- ============ PAGES ============ -->
  <main id="app">

    <!-- HOME -->
    <section id="page-home" class="page active">
      <div class="hero">
        <canvas id="hero-canvas"></canvas>
        <div class="hero-content">
          <h1 class="glitch" data-text="USA STREETLIFTING">USA STREETLIFTING</h1>
          <p class="hero-tag">OFFICIAL JUDGE CERTIFICATION PORTAL</p>
          <p class="hero-sub typewriter">Become a certified streetlifting judge. Uphold the standard.</p>
          <div class="hero-btns">
            <button data-nav="register" class="btn btn-primary btn-glow" id="hero-register">Apply Now</button>
            <button data-nav="login" class="btn btn-outline btn-glow" id="hero-login">Judge Login</button>
          </div>
        </div>
      </div>

      <!-- Stats counter -->
      <div class="stats-bar">
        <div class="stat fade-up">
          <span class="stat-num" data-target="350">0</span>+
          <span class="stat-label">Certified Judges</span>
        </div>
        <div class="stat fade-up">
          <span class="stat-num" data-target="120">0</span>+
          <span class="stat-label">Competitions Judged</span>
        </div>
        <div class="stat fade-up">
          <span class="stat-num" data-target="42">0</span>
          <span class="stat-label">States Covered</span>
        </div>
      </div>

      <!-- How it works -->
      <div class="section-header fade-up">
        <h2>How Certification Works</h2>
        <p class="muted">Three steps to becoming an official USA Streetlifting judge</p>
      </div>

      <div class="steps">
        <div class="step fade-up">
          <div class="step-num">1</div>
          <h3>Register &amp; Apply</h3>
          <p>Create your account and fill out the judge application form.</p>
        </div>
        <div class="step-arrow fade-up">&#9654;</div>
        <div class="step fade-up">
          <div class="step-num">2</div>
          <h3>Pay Certification Fee</h3>
          <p>Submit the certification fee via Venmo to process your application.</p>
        </div>
        <div class="step-arrow fade-up">&#9654;</div>
        <div class="step fade-up">
          <div class="step-num">3</div>
          <h3>Get Certified</h3>
          <p>Complete the requirements and receive your official judge credential.</p>
        </div>
      </div>

      <div class="features">
        <div class="card fade-up">
          <div class="card-icon">&#9878;</div>
          <h3>Level 1 – Local Judge</h3>
          <p>Judge local and regional streetlifting meets. Entry-level certification for new officials.</p>
        </div>
        <div class="card fade-up">
          <div class="card-icon">&#9733;</div>
          <h3>Level 2 – State Judge</h3>
          <p>Certified to judge state-level competitions. Requires Level 1 plus practical experience.</p>
        </div>
        <div class="card fade-up">
          <div class="card-icon">&#9812;</div>
          <h3>Level 3 – National Judge</h3>
          <p>Head judge at national events. The highest level of certification in US streetlifting.</p>
        </div>
      </div>
    </section>

    <!-- REGISTER -->
    <section id="page-register" class="page">
      <div class="form-container slide-in">
        <h2>Judge Application</h2>
        <form id="register-form">
          <div class="input-group">
            <label for="reg-name">Full Legal Name</label>
            <input id="reg-name" type="text" required minlength="2" maxlength="100" autocomplete="name" placeholder="John Doe" />
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="reg-email">Email</label>
            <input id="reg-email" type="email" required autocomplete="email" placeholder="you@example.com" />
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="reg-state">State</label>
            <select id="reg-state" required class="select-input">
              <option value="">Select your state...</option>
              <option>Alabama</option><option>Alaska</option><option>Arizona</option><option>Arkansas</option>
              <option>California</option><option>Colorado</option><option>Connecticut</option><option>Delaware</option>
              <option>Florida</option><option>Georgia</option><option>Hawaii</option><option>Idaho</option>
              <option>Illinois</option><option>Indiana</option><option>Iowa</option><option>Kansas</option>
              <option>Kentucky</option><option>Louisiana</option><option>Maine</option><option>Maryland</option>
              <option>Massachusetts</option><option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
              <option>Missouri</option><option>Montana</option><option>Nebraska</option><option>Nevada</option>
              <option>New Hampshire</option><option>New Jersey</option><option>New Mexico</option><option>New York</option>
              <option>North Carolina</option><option>North Dakota</option><option>Ohio</option><option>Oklahoma</option>
              <option>Oregon</option><option>Pennsylvania</option><option>Rhode Island</option><option>South Carolina</option>
              <option>South Dakota</option><option>Tennessee</option><option>Texas</option><option>Utah</option>
              <option>Vermont</option><option>Virginia</option><option>Washington</option><option>West Virginia</option>
              <option>Wisconsin</option><option>Wyoming</option>
            </select>
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="reg-experience">Judging / Lifting Experience</label>
            <textarea id="reg-experience" class="textarea-input" rows="3" placeholder="Briefly describe any relevant experience..." maxlength="500"></textarea>
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="reg-password">Password</label>
            <div class="password-wrap">
              <input id="reg-password" type="password" required minlength="8" maxlength="128" autocomplete="new-password" placeholder="Min 8 characters" />
              <button type="button" class="toggle-pw" data-toggle-pw="reg-password">Show</button>
            </div>
            <div class="input-underline"></div>
            <div class="password-strength">
              <div class="pw-bar" id="pw-bar"></div>
            </div>
            <span class="pw-label" id="pw-label"></span>
          </div>
          <div id="register-error" class="error-msg"></div>
          <button type="submit" class="btn btn-primary btn-full btn-glow" id="register-btn">
            <span class="btn-text">Register</span>
            <span class="btn-spinner hidden"></span>
          </button>
        </form>
        <p class="switch-link">Already have an account? <a data-nav="login">Login</a></p>
      </div>
    </section>

    <!-- LOGIN -->
    <section id="page-login" class="page">
      <div class="form-container slide-in">
        <h2>Login</h2>
        <form id="login-form">
          <div class="input-group">
            <label for="login-email">Email</label>
            <input id="login-email" type="email" required autocomplete="email" placeholder="you@example.com" />
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="login-password">Password</label>
            <div class="password-wrap">
              <input id="login-password" type="password" required autocomplete="current-password" placeholder="Your password" />
              <button type="button" class="toggle-pw" data-toggle-pw="login-password">Show</button>
            </div>
            <div class="input-underline"></div>
          </div>
          <div id="login-error" class="error-msg"></div>
          <button type="submit" class="btn btn-primary btn-full btn-glow" id="login-btn">
            <span class="btn-text">Login</span>
            <span class="btn-spinner hidden"></span>
          </button>
        </form>
        <p class="switch-link">Don't have an account? <a data-nav="register">Register</a></p>
      </div>
    </section>

    <!-- DASHBOARD -->
    <section id="page-dashboard" class="page">
      <div class="dash-container slide-in">
        <div class="dash-header">
          <div class="avatar" id="dash-avatar"></div>
          <div>
            <h2>Welcome, <span id="dash-name"></span></h2>
            <p class="dash-email" id="dash-email"></p>
          </div>
        </div>

        <!-- Certification Status Card -->
        <div class="cert-card fade-up">
          <div class="cert-card-inner">
            <div class="cert-badge" id="cert-badge">
              <svg viewBox="0 0 80 80" width="80" height="80">
                <circle cx="40" cy="40" r="36" fill="none" stroke="#333" stroke-width="3"/>
                <circle cx="40" cy="40" r="36" fill="none" stroke="var(--clr-primary)" stroke-width="3"
                  stroke-dasharray="226" stroke-dashoffset="226" id="cert-progress"/>
                <text x="40" y="44" text-anchor="middle" fill="var(--clr-text)" font-family="Oswald" font-size="16" id="cert-level">--</text>
              </svg>
            </div>
            <div class="cert-info">
              <h3>Judge Certification</h3>
              <p class="cert-status" id="cert-status">No certification yet</p>
              <p class="muted" id="cert-detail">Complete payment to begin the certification process.</p>
            </div>
          </div>
          <button data-nav="payment" class="btn btn-primary btn-glow btn-sm" id="cert-action-btn">Start Certification</button>
        </div>

        <div class="dash-section fade-up">
          <h3>Payment &amp; Certification History</h3>
          <div id="payment-history">
            <div class="skeleton-loader">
              <div class="skeleton-line"></div>
              <div class="skeleton-line short"></div>
              <div class="skeleton-line"></div>
            </div>
          </div>
        </div>

        <button data-nav="payment" class="btn btn-primary btn-glow">Pay Certification Fee</button>
      </div>
    </section>

    <!-- PAYMENT -->
    <section id="page-payment" class="page">
      <div class="pay-container slide-in">
        <h2>Certification Payment</h2>
        <p>Select your certification level below and complete payment via Venmo.</p>

        <div id="payment-options" class="pay-options">
          <div class="skeleton-loader">
            <div class="skeleton-line"></div>
            <div class="skeleton-line short"></div>
          </div>
        </div>

        <div id="venmo-link-area" class="venmo-area hidden">
          <div class="checkmark-circle">
            <svg viewBox="0 0 52 52"><circle cx="26" cy="26" r="25" fill="none"/><path fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/></svg>
          </div>
          <h3>Complete Your Payment</h3>
          <p id="venmo-amount" class="venmo-amount-text"></p>
          <div class="venmo-btns">
            <a id="venmo-web" href="#" target="_blank" rel="noopener" class="btn btn-venmo btn-glow">Pay with Venmo (Web)</a>
            <a id="venmo-app" href="#" class="btn btn-outline btn-glow">Open Venmo App</a>
          </div>
          <p class="muted">After payment is confirmed, your certification status will be updated on your dashboard.</p>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="page-about" class="page">
      <div class="content-container fade-up">
        <h1 class="page-title">About USA Streetlifting</h1>
        <div class="about-grid">
          <div class="about-text">
            <h2>Our Mission</h2>
            <p>USA Streetlifting is the premier governing body for streetlifting competitions in the United States. We are dedicated to promoting fair competition, athlete safety, and the growth of streetlifting as a recognized sport across all 50 states.</p>
            <h2>What is Streetlifting?</h2>
            <p>Streetlifting combines elements of calisthenics and weighted bodyweight exercises, primarily focusing on weighted pull-ups and weighted dips. Athletes compete to lift the maximum additional weight while performing strict-form repetitions.</p>
            <h2>Our History</h2>
            <p>Founded by a group of passionate athletes and coaches, USA Streetlifting has grown from grassroots local meets to sanctioning state and national-level competitions. Our certified judges ensure every lift is held to the highest standard.</p>
          </div>
          <div class="about-sidebar">
            <div class="info-card">
              <div class="info-card-icon">&#9878;</div>
              <h3>Fair Competition</h3>
              <p>All meets follow standardized rules with certified judges ensuring every lift counts.</p>
            </div>
            <div class="info-card">
              <div class="info-card-icon">&#9733;</div>
              <h3>National Rankings</h3>
              <p>Compete to earn your place on the official USA Streetlifting leaderboard.</p>
            </div>
            <div class="info-card">
              <div class="info-card-icon">&#9883;</div>
              <h3>Community</h3>
              <p>Join a growing community of athletes, coaches, and officials dedicated to the sport.</p>
            </div>
          </div>
        </div>

        <div class="about-cta">
          <h2>Ready to Get Involved?</h2>
          <p>Whether you want to compete, judge, or organize events, we'd love to have you.</p>
          <div class="hero-btns">
            <button data-nav="register" class="btn btn-primary btn-glow">Apply as Judge</button>
            <button data-nav="contact" class="btn btn-outline btn-glow">Contact Us</button>
          </div>
        </div>
      </div>
    </section>

    <!-- RULES -->
    <section id="page-rules" class="page">
      <div class="content-container fade-up">
        <h1 class="page-title">Competition Rules &amp; Standards</h1>

        <div class="rules-toc">
          <h3>Contents</h3>
          <ol>
            <li>Competition Divisions</li>
            <li>Weighted Pull-Up Rules</li>
            <li>Weighted Dip Rules</li>
            <li>Judging Criteria</li>
            <li>Equipment Standards</li>
            <li>Scoring &amp; Awards</li>
          </ol>
        </div>

        <div class="rule-section">
          <h2>1. Competition Divisions</h2>
          <div class="rule-content">
            <p>Athletes compete in weight classes based on bodyweight. Weigh-ins occur the morning of competition.</p>
            <table class="rules-table">
              <thead><tr><th>Division</th><th>Men (kg)</th><th>Women (kg)</th></tr></thead>
              <tbody>
                <tr><td>Lightweight</td><td>&le; 70</td><td>&le; 55</td></tr>
                <tr><td>Middleweight</td><td>70.1 – 85</td><td>55.1 – 67</td></tr>
                <tr><td>Heavyweight</td><td>85.1 – 100</td><td>67.1 – 80</td></tr>
                <tr><td>Super Heavyweight</td><td>100.1+</td><td>80.1+</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="rule-section">
          <h2>2. Weighted Pull-Up Rules</h2>
          <div class="rule-content">
            <ul class="rule-list">
              <li>Athlete must start from a full dead hang (arms fully extended).</li>
              <li>Chin must clearly break the plane of the bar at the top of each rep.</li>
              <li>No kipping, swinging, or use of momentum is permitted.</li>
              <li>Weight must be attached via an approved dip/pull-up belt.</li>
              <li>Each attempt allows 3 repetitions for max weight or 1-rep max format depending on meet rules.</li>
            </ul>
          </div>
        </div>

        <div class="rule-section">
          <h2>3. Weighted Dip Rules</h2>
          <div class="rule-content">
            <ul class="rule-list">
              <li>Athlete must start at full arm lockout at the top position.</li>
              <li>Elbows must break 90&deg; at the bottom of each rep (upper arm parallel or below).</li>
              <li>Full lockout must be achieved at the top for the rep to count.</li>
              <li>No excessive lean or bounce is permitted.</li>
              <li>Parallel bars or approved dip station must be used.</li>
            </ul>
          </div>
        </div>

        <div class="rule-section">
          <h2>4. Judging Criteria</h2>
          <div class="rule-content">
            <p>Three certified judges evaluate each attempt. A majority (2 of 3) must approve the lift with a white light for it to count. Judges evaluate:</p>
            <div class="criteria-grid">
              <div class="criteria-item">
                <span class="criteria-icon">&#10004;</span>
                <div>
                  <strong>Range of Motion</strong>
                  <p>Full ROM must be achieved on every repetition.</p>
                </div>
              </div>
              <div class="criteria-item">
                <span class="criteria-icon">&#10004;</span>
                <div>
                  <strong>Strict Form</strong>
                  <p>No kipping, swinging, or momentum-assisted movement.</p>
                </div>
              </div>
              <div class="criteria-item">
                <span class="criteria-icon">&#10004;</span>
                <div>
                  <strong>Control</strong>
                  <p>Controlled movement through the entire rep. No drops or rebounds.</p>
                </div>
              </div>
              <div class="criteria-item">
                <span class="criteria-icon">&#10004;</span>
                <div>
                  <strong>Equipment Check</strong>
                  <p>Weight and belt verified before each attempt.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="rule-section">
          <h2>5. Equipment Standards</h2>
          <div class="rule-content">
            <ul class="rule-list">
              <li>Only calibrated plates or certified weight plates are permitted in competition.</li>
              <li>Dip/pull-up belts must be commercially manufactured (no DIY chains without belt).</li>
              <li>Chalk and wrist wraps are permitted. Gloves are not.</li>
              <li>Pull-up bar diameter: 28–32 mm. Dip bar width: 55–60 cm center-to-center.</li>
            </ul>
          </div>
        </div>

        <div class="rule-section">
          <h2>6. Scoring &amp; Awards</h2>
          <div class="rule-content">
            <p>Athletes are ranked by their best successful attempt in each event. In case of a tie, the athlete with the lower bodyweight wins. Awards are given for:</p>
            <ul class="rule-list">
              <li>1st, 2nd, 3rd place in each weight class per event.</li>
              <li>Best overall lifter (Wilks/Dots-adjusted coefficient).</li>
              <li>Best newcomer (first sanctioned competition).</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- PROFILE -->
    <section id="page-profile" class="page">
      <div class="form-container slide-in" style="max-width:520px">
        <h2>My Profile</h2>

        <div class="profile-header">
          <div class="avatar avatar-lg" id="profile-avatar"></div>
          <div>
            <p class="profile-name" id="profile-display-name"></p>
            <p class="muted" id="profile-display-email"></p>
            <p class="muted profile-joined" id="profile-joined"></p>
          </div>
        </div>

        <form id="profile-form">
          <div class="input-group">
            <label for="profile-name">Full Name</label>
            <input id="profile-name" type="text" required minlength="2" maxlength="100" />
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="profile-email">Email</label>
            <input id="profile-email" type="email" disabled class="input-disabled" />
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="profile-phone">Phone (optional)</label>
            <input id="profile-phone" type="tel" maxlength="20" placeholder="(555) 123-4567" />
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="profile-state">State</label>
            <select id="profile-state" class="select-input">
              <option value="">Select your state...</option>
              <option>Alabama</option><option>Alaska</option><option>Arizona</option><option>Arkansas</option>
              <option>California</option><option>Colorado</option><option>Connecticut</option><option>Delaware</option>
              <option>Florida</option><option>Georgia</option><option>Hawaii</option><option>Idaho</option>
              <option>Illinois</option><option>Indiana</option><option>Iowa</option><option>Kansas</option>
              <option>Kentucky</option><option>Louisiana</option><option>Maine</option><option>Maryland</option>
              <option>Massachusetts</option><option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
              <option>Missouri</option><option>Montana</option><option>Nebraska</option><option>Nevada</option>
              <option>New Hampshire</option><option>New Jersey</option><option>New Mexico</option><option>New York</option>
              <option>North Carolina</option><option>North Dakota</option><option>Ohio</option><option>Oklahoma</option>
              <option>Oregon</option><option>Pennsylvania</option><option>Rhode Island</option><option>South Carolina</option>
              <option>South Dakota</option><option>Tennessee</option><option>Texas</option><option>Utah</option>
              <option>Vermont</option><option>Virginia</option><option>Washington</option><option>West Virginia</option>
              <option>Wisconsin</option><option>Wyoming</option>
            </select>
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="profile-experience">Judging / Lifting Experience</label>
            <textarea id="profile-experience" class="textarea-input" rows="3" maxlength="500"></textarea>
            <div class="input-underline"></div>
          </div>
          <div id="profile-error" class="error-msg"></div>
          <button type="submit" class="btn btn-primary btn-full btn-glow" id="profile-save-btn">
            <span class="btn-text">Save Changes</span>
            <span class="btn-spinner hidden"></span>
          </button>
        </form>

        <hr class="divider" />

        <h3 class="subsection-title">Change Password</h3>
        <form id="password-form">
          <div class="input-group">
            <label for="pw-current">Current Password</label>
            <div class="password-wrap">
              <input id="pw-current" type="password" required autocomplete="current-password" />
              <button type="button" class="toggle-pw" data-toggle-pw="pw-current">Show</button>
            </div>
            <div class="input-underline"></div>
          </div>
          <div class="input-group">
            <label for="pw-new">New Password</label>
            <div class="password-wrap">
              <input id="pw-new" type="password" required minlength="8" maxlength="128" autocomplete="new-password" />
              <button type="button" class="toggle-pw" data-toggle-pw="pw-new">Show</button>
            </div>
            <div class="input-underline"></div>
            <div class="password-strength"><div class="pw-bar" id="pw-bar"></div></div>
            <span class="pw-label" id="pw-label"></span>
          </div>
          <div class="input-group">
            <label for="pw-confirm">Confirm New Password</label>
            <div class="password-wrap">
              <input id="pw-confirm" type="password" required minlength="8" maxlength="128" autocomplete="new-password" />
              <button type="button" class="toggle-pw" data-toggle-pw="pw-confirm">Show</button>
            </div>
            <div class="input-underline"></div>
          </div>
          <div id="password-error" class="error-msg"></div>
          <button type="submit" class="btn btn-outline btn-full" id="password-btn">
            <span class="btn-text">Change Password</span>
            <span class="btn-spinner hidden"></span>
          </button>
        </form>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="page-contact" class="page">
      <div class="content-container fade-up">
        <h1 class="page-title">Contact Us</h1>
        <div class="contact-grid">
          <div class="contact-form-wrap">
            <p>Have questions about certification, competitions, or anything else? Send us a message and we'll get back to you as soon as possible.</p>
            <form id="contact-form">
              <div class="input-group">
                <label for="contact-name">Your Name</label>
                <input id="contact-name" type="text" required maxlength="100" placeholder="John Doe" />
                <div class="input-underline"></div>
              </div>
              <div class="input-group">
                <label for="contact-email">Your Email</label>
                <input id="contact-email" type="email" required placeholder="you@example.com" />
                <div class="input-underline"></div>
              </div>
              <div class="input-group">
                <label for="contact-subject">Subject</label>
                <select id="contact-subject" class="select-input" required>
                  <option value="">Select a topic...</option>
                  <option value="certification">Judge Certification</option>
                  <option value="competition">Competition Inquiry</option>
                  <option value="payment">Payment Issue</option>
                  <option value="technical">Technical Support</option>
                  <option value="other">Other</option>
                </select>
                <div class="input-underline"></div>
              </div>
              <div class="input-group">
                <label for="contact-message">Message</label>
                <textarea id="contact-message" class="textarea-input" rows="5" required maxlength="2000" placeholder="Describe your question or issue..."></textarea>
                <div class="input-underline"></div>
              </div>
              <div id="contact-error" class="error-msg"></div>
              <button type="submit" class="btn btn-primary btn-full btn-glow" id="contact-btn">
                <span class="btn-text">Send Message</span>
                <span class="btn-spinner hidden"></span>
              </button>
            </form>
          </div>
          <div class="contact-info">
            <div class="contact-info-card">
              <h3>&#9993; Email</h3>
              <p>info@usastreetlifting.org</p>
            </div>
            <div class="contact-info-card">
              <h3>&#9742; Phone</h3>
              <p>(555) 123-4567</p>
            </div>
            <div class="contact-info-card">
              <h3>&#9872; Headquarters</h3>
              <p>USA Streetlifting Federation<br>PO Box 12345<br>Dallas, TX 75001</p>
            </div>
            <div class="contact-info-card">
              <h3>&#128337; Hours</h3>
              <p>Mon – Fri: 9 AM – 5 PM CT<br>Weekends: Closed</p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- ============ FOOTER ============ -->
  <footer>
    <div class="footer-inner">
      <div class="footer-links">
        <a data-nav="about">About</a>
        <a data-nav="rules">Rules</a>
        <a data-nav="contact">Contact</a>
      </div>
      <p>&copy; 2026 USA Streetlifting Federation. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/app.js"></script>
</body>
</html>
